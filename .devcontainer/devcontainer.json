{
  "name": "Basic Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "installTools": true,
      "version": "3.10"
    },
    "ghcr.io/postfinance/devcontainer-features/node:1": {
      "version": "20.11.1",
      "npmVersion": "10.5.0",
      "yarnVersion": "1.22.22",
      "pnpmVersion": "9.14.2",
      "corepackVersion": "0.34.0",
      "downloadUrl": "https://mycompany.com/artifactory/nodejs-generic-remote/dist",
      "globalNpmRegistry": "https://mycompany.com/artifactory/api/npm/npm/"
    }
  },
  "postCreateCommand": ".devcontainer/postCreate.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "1yib.nodejs-bundle"
      ]
    }
  }
}